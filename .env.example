# GitHub Personal Access Token (fetcher 용)
GITHUB_TOKEN=

# Claude subscription auth (claude-agent-sdk)
# IMPORTANT: ANTHROPIC_API_KEY must be UNSET — it takes precedence over the OAuth token
# and will cause the SDK to fall back to paid API auth instead of subscription auth.
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: override the default model
# ANTHROPIC_MODEL=claude-sonnet-4-6
