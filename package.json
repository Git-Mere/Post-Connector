{
  "name": "post-connector",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub repo 하나로 여러 플랫폼에 콘텐츠를 자동 생성/발행하는 도구",
  "license": "MIT",
  "type": "module",
  "main": "dist/api/server.js",
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "typecheck": "tsc --noEmit",
    "generate": "tsx src/cli.ts"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.3.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.168",
    "@octokit/graphql": "^9.0.3",
    "@octokit/rest": "^22.0.1",
    "bullmq": "^5.77.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
